# ============================================================================
# .env — Environment Configuration
# ============================================================================
# This file contains all configurable settings for the LoadBalancer-Prototype.
# Values here are loaded into process.env at startup via the dotenv package.
# ============================================================================

# --- Load Balancer -----------------------------------------------------------
# Port the main load balancer listens on for incoming client requests.
LOAD_BALANCER_PORT = 3000

# --- Logging -----------------------------------------------------------------
# Minimum log level. Messages below this level are suppressed.
# Levels (most → least severe): error, warn, info, http, verbose, debug, silly
LOG_LEVEL = info

# --- Backend Servers ---------------------------------------------------------
# TCP ports for each backend server. The load balancer forwards requests
# to these ports based on the selected scheduling algorithm.
SERVER_1_PORT = 4000
SERVER_2_PORT = 4001
SERVER_3_PORT = 4002

# --- Scheduling Algorithm ----------------------------------------------------
# Which algorithm the load balancer uses to distribute requests.
# Accepted values:
#   round-robin           → Cycles through servers sequentially (1→2→3→1→...)
#   weighted-round-robin  → Same cycle, but servers with higher weight get more turns
#   least-connections     → Picks the server with the fewest active requests
SCHEDULING_ALGORITHM = round-robin